{
  "name": "ermis-call-core",
  "version": "0.1.0",
  "description": "Ermis Call Core SDK - WebAssembly-based peer-to-peer communication",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/wasm/*.wasm"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "dev": "concurrently \"npm run watch\" \"cd examples/demo && npm run dev\"",
    "demo": "cd examples/demo && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
